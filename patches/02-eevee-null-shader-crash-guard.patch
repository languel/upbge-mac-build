+  /* Bail out if any of the deferred lighting shaders failed to compile.
+   * StaticShader::is_ready() returns true on either success OR failure
+   * (the failure path sets failed_=true while leaving shader_=nullptr),
+   * which means static_shaders_load_async can mark DEFERRED_LIGHTING_SHADERS
+   * as "loaded" and we end up here even though some shaders are null.
+   * Without this guard, GPU_shader_get_default_constant_state(nullptr) below
+   * dereferences a null pointer and crashes the viewport. Observed on macOS
+   * Metal where shader compilation can fail silently. */
+  for (int i : IndexRange(3)) {
+    eShaderType type = eShaderType(DEFERRED_LIGHT_SINGLE + i);
+    if (static_shader_get(type) == nullptr) {
+      /* One-shot diagnostic: write which shader failed so we can debug
+       * the underlying compilation issue. Write only once per type. */
+      static std::array<bool, 3> reported = {false, false, false};
+      if (!reported[i]) {
+        reported[i] = true;
+        const char *info_name = static_shader_create_info_name_get(type);
+        fprintf(stderr,
+                "[UPBGE-PATCH] Deferred light shader failed to compile: %s "
+                "(eShaderType=%d). Viewport will skip render to avoid crash.\n",
+                info_name ? info_name : "?",
+                int(type));
+        FILE *f = fopen("/tmp/upbge_shader_fail.log", "a");
+        if (f) {
+          fprintf(f, "%s (eShaderType=%d)\n", info_name ? info_name : "?", int(type));
+          fclose(f);
+        }
+      }
+      return false;
+    }
+  }
